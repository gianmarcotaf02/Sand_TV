<?xml version="1.0" encoding="utf-8"?>
<!-- NOTE: Premium dialog glassmorphism background -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Dark base for OLED -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_elevated"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>
    
    <!-- Glass overlay -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_background"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>
    
    <!-- Accent border -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="@color/glass_border"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>
    
</layer-list>
