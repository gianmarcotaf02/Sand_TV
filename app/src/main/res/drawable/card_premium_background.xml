<?xml version="1.0" encoding="utf-8"?>
<!-- NOTE: Premium card background with subtle gradient and rounded corners -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Focused State -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Glow effect behind -->
            <item android:bottom="-4dp" android:left="-4dp" android:right="-4dp" android:top="-4dp">
                <shape android:shape="rectangle">
                    <corners android:radius="16dp"/>
                    <solid android:color="@color/focus_glow"/>
                </shape>
            </item>
            <!-- Card background -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="12dp"/>
                    <solid android:color="@color/card_background_focused"/>
                    <stroke android:width="3dp" android:color="@color/focus_ring"/>
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Pressed State -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="12dp"/>
            <solid android:color="@color/card_background_hover"/>
            <stroke android:width="2dp" android:color="@color/accent"/>
        </shape>
    </item>
    
    <!-- Default State -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp"/>
            <solid android:color="@color/card_background"/>
            <stroke android:width="1dp" android:color="@color/card_border"/>
        </shape>
    </item>
    
</selector>
