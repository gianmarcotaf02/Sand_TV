<?xml version="1.0" encoding="utf-8"?>
<!-- NOTE: Premium glass button with glow focus -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Focused State -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Glow -->
            <item android:bottom="-3dp" android:left="-3dp" android:right="-3dp" android:top="-3dp">
                <shape android:shape="rectangle">
                    <corners android:radius="17dp"/>
                    <solid android:color="@color/focus_glow"/>
                </shape>
            </item>
            <!-- Glass fill -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/glass_background_light"/>
                    <corners android:radius="14dp"/>
                </shape>
            </item>
            <!-- Focus border -->
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="2dp" android:color="@color/focus_ring"/>
                    <corners android:radius="14dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Pressed State -->
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/glass_background_light"/>
                    <corners android:radius="14dp"/>
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="1dp" android:color="@color/accent"/>
                    <corners android:radius="14dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Default State -->
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/glass_background"/>
                    <corners android:radius="14dp"/>
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="1dp" android:color="@color/glass_border_subtle"/>
                    <corners android:radius="14dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    
</selector>
