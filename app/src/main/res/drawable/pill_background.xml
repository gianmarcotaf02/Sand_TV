<?xml version="1.0" encoding="utf-8"?>
<!-- NOTE: Premium pill/tab background with enhanced focus states -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Selected + Focused -->
    <item android:state_selected="true" android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/accent"/>
            <corners android:radius="28dp"/>
            <stroke android:width="2dp" android:color="@color/accent_light"/>
        </shape>
    </item>
    
    <!-- Selected State -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/pill_background_selected"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>
    
    <!-- Focused State -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Subtle glow -->
            <item android:bottom="-2dp" android:left="-2dp" android:right="-2dp" android:top="-2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="30dp"/>
                    <solid android:color="@color/focus_glow"/>
                </shape>
            </item>
            <!-- Pill -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/pill_background_hover"/>
                    <stroke android:width="2dp" android:color="@color/focus_ring"/>
                    <corners android:radius="28dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Pressed State -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/pill_background_hover"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>
    
    <!-- Default State -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/pill_background"/>
            <stroke android:width="1dp" android:color="@color/pill_border"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>
    
</selector>
