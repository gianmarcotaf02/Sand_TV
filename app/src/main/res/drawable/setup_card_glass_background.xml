<?xml version="1.0" encoding="utf-8"?>
<!-- Enhanced glassmorphism background for setup card with purple accent glow -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow effect -->
    <item android:bottom="2dp" android:left="2dp" android:right="2dp" android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#10FFFFFF" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <!-- Main glass background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#18FFFFFF"
                android:endColor="#08FFFFFF" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <!-- Subtle border with purple accent -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#408B5CF6" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>
