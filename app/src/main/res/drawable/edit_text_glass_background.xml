<?xml version="1.0" encoding="utf-8"?>
<!-- Glassmorphism input field background -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#18FFFFFF" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="2dp" android:color="@color/accent" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#0DFFFFFF" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="1dp" android:color="#20FFFFFF" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
