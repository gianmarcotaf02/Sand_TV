<?xml version="1.0" encoding="utf-8"?>
<!-- NOTE: Premium circle button with glow focus - Player controls -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Focused state -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Glow -->
            <item android:left="-4dp" android:top="-4dp" android:right="-4dp" android:bottom="-4dp">
                <shape android:shape="oval">
                    <solid android:color="@color/focus_glow" />
                </shape>
            </item>
            <!-- Button -->
            <item>
                <shape android:shape="oval">
                    <solid android:color="@color/glass_background_light" />
                    <stroke android:width="2dp" android:color="@color/focus_ring" />
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="@color/selection_background" />
            <stroke android:width="1dp" android:color="@color/accent" />
        </shape>
    </item>
    
    <!-- Default state -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/glass_background_dark" />
            <stroke android:width="1dp" android:color="@color/glass_border_subtle" />
        </shape>
    </item>
    
</selector>
