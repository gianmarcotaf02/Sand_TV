<?xml version="1.0" encoding="utf-8"?>
<!-- NOTE: Premium primary button with gradient and glow focus -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Focused State - Bright with glow -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Outer glow -->
            <item android:bottom="-4dp" android:left="-4dp" android:right="-4dp" android:top="-4dp">
                <shape android:shape="rectangle">
                    <corners android:radius="18dp"/>
                    <solid android:color="@color/focus_glow"/>
                </shape>
            </item>
            <!-- Button with gradient -->
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="135"
                        android:startColor="@color/accent_light"
                        android:endColor="@color/accent"
                        android:type="linear"/>
                    <corners android:radius="14dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Pressed State -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/accent_dark"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
    
    <!-- Disabled State -->
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/pill_background"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
    
    <!-- Default State - Gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="@color/accent"
                android:endColor="@color/accent_dark"
                android:type="linear"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
    
</selector>
