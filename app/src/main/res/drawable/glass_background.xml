<?xml version="1.0" encoding="utf-8"?>
<!-- NOTE: Premium glassmorphism effect background -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Focused State -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Glass fill -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/glass_background_light"/>
                    <corners android:radius="20dp"/>
                </shape>
            </item>
            <!-- Focused border -->
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="2dp" android:color="@color/focus_ring"/>
                    <corners android:radius="20dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Default State -->
    <item>
        <layer-list>
            <!-- Glass fill -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/glass_background"/>
                    <corners android:radius="20dp"/>
                </shape>
            </item>
            <!-- Subtle border -->
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="1dp" android:color="@color/glass_border_subtle"/>
                    <corners android:radius="20dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    
</selector>
