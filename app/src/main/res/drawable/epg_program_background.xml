<?xml version="1.0" encoding="utf-8"?>
<!-- Background for program block in EPG timeline - OLED Theme -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused state - violet accent -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#1C1C1C" />
            <corners android:radius="4dp" />
            <stroke android:width="2dp" android:color="#8B5CF6" />
        </shape>
    </item>
    <!-- Selected/current program -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#1A1A2A" />
            <corners android:radius="4dp" />
            <stroke android:width="1dp" android:color="#8B5CF6" />
        </shape>
    </item>
    <!-- Default state - OLED dark -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#141414" />
            <corners android:radius="4dp" />
        </shape>
    </item>
</selector>
