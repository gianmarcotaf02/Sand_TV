<?xml version="1.0" encoding="utf-8"?>
<!-- NOTE: Premium selectable item background for lists -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Focused State - Accent highlight -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Glow behind -->
            <item android:left="-2dp" android:right="-2dp" android:top="-2dp" android:bottom="-2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp"/>
                    <solid android:color="@color/focus_glow"/>
                </shape>
            </item>
            <!-- Fill -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/selection_background"/>
                    <corners android:radius="12dp"/>
                    <stroke android:width="2dp" android:color="@color/focus_ring"/>
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Selected State -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/selection_background"/>
            <corners android:radius="12dp"/>
            <stroke android:width="1dp" android:color="@color/accent"/>
        </shape>
    </item>
    
    <!-- Pressed State -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/selection_background"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    
    <!-- Default State -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    
</selector>
