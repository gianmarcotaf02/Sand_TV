<?xml version="1.0" encoding="utf-8"?>
<!-- NOTE: Premium tab pill with gradient and glow focus - Streaming style -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Selected + Focused -->
    <item android:state_selected="true" android:state_focused="true">
        <layer-list>
            <!-- Glow -->
            <item android:bottom="-3dp" android:left="-3dp" android:right="-3dp" android:top="-3dp">
                <shape android:shape="rectangle">
                    <corners android:radius="15dp"/>
                    <solid android:color="@color/focus_glow"/>
                </shape>
            </item>
            <!-- Tab -->
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:type="linear"
                        android:angle="135"
                        android:startColor="@color/accent_light"
                        android:endColor="@color/accent"/>
                    <corners android:radius="12dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Selected -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="@color/accent"
                android:endColor="@color/accent_dark"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    
    <!-- Focused -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Subtle glow -->
            <item android:bottom="-2dp" android:left="-2dp" android:right="-2dp" android:top="-2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp"/>
                    <solid android:color="@color/focus_glow"/>
                </shape>
            </item>
            <!-- Tab -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/pill_background_hover"/>
                    <stroke android:width="2dp" android:color="@color/focus_ring"/>
                    <corners android:radius="12dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Default -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/pill_background"/>
            <stroke android:width="1dp" android:color="@color/glass_border_subtle"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    
</selector>
