<?xml version="1.0" encoding="utf-8"?>
<!-- NOTE: Premium card scale animation - Smooth streaming-style focus -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Focused state: scale up with elevation -->
    <item android:state_focused="true">
        <set android:ordering="together">
            <objectAnimator
                android:propertyName="scaleX"
                android:duration="180"
                android:valueTo="1.06"
                android:interpolator="@android:interpolator/fast_out_slow_in"
                android:valueType="floatType" />
            <objectAnimator
                android:propertyName="scaleY"
                android:duration="180"
                android:valueTo="1.06"
                android:interpolator="@android:interpolator/fast_out_slow_in"
                android:valueType="floatType" />
            <objectAnimator
                android:propertyName="translationZ"
                android:duration="180"
                android:valueTo="12dp"
                android:interpolator="@android:interpolator/fast_out_slow_in"
                android:valueType="floatType" />
        </set>
    </item>
    
    <!-- Pressed state: slight shrink for feedback -->
    <item android:state_pressed="true">
        <set android:ordering="together">
            <objectAnimator
                android:propertyName="scaleX"
                android:duration="80"
                android:valueTo="0.98"
                android:interpolator="@android:interpolator/fast_out_linear_in"
                android:valueType="floatType" />
            <objectAnimator
                android:propertyName="scaleY"
                android:duration="80"
                android:valueTo="0.98"
                android:interpolator="@android:interpolator/fast_out_linear_in"
                android:valueType="floatType" />
            <objectAnimator
                android:propertyName="translationZ"
                android:duration="80"
                android:valueTo="4dp"
                android:valueType="floatType" />
        </set>
    </item>
    
    <!-- Default state: normal size -->
    <item>
        <set android:ordering="together">
            <objectAnimator
                android:propertyName="scaleX"
                android:duration="200"
                android:valueTo="1.0"
                android:interpolator="@android:interpolator/fast_out_slow_in"
                android:valueType="floatType" />
            <objectAnimator
                android:propertyName="scaleY"
                android:duration="200"
                android:valueTo="1.0"
                android:interpolator="@android:interpolator/fast_out_slow_in"
                android:valueType="floatType" />
            <objectAnimator
                android:propertyName="translationZ"
                android:duration="200"
                android:valueTo="0dp"
                android:interpolator="@android:interpolator/fast_out_slow_in"
                android:valueType="floatType" />
        </set>
    </item>
    
</selector>
